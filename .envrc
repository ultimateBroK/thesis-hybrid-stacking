#!/usr/bin/env bash
# direnv: comprehensive env loader for pixi/uv/etc.
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$PROJECT_ROOT"

has() { command -v "$1" >/dev/null 2>&1; }

# Prefer project manager that defines the *full* runtime env (PATH + vars).
# Priority: pixi -> uv venv -> poetry/pdm/pipenv/rye -> conda-like -> fallback python layout.

activate_pixi() {
  # Pixi can export a complete environment (PATH + many vars).
  # Using shell-hook keeps it aligned with `pixi run ...` behavior.
  has pixi || return 1
  [ -f "pixi.lock" ] || grep -qs '^\[tool\.pixi\.' pyproject.toml 2>/dev/null || [ -f "pixi.toml" ] || return 1
  # Some completion scripts sourced by pixi don't tolerate `set -u`.
  # Temporarily disable nounset while evaluating the hook.
  set +u
  # shellcheck disable=SC1090
  eval "$(pixi shell-hook -s bash)"
  set -u
  return 0
}

activate_venv() {
  local venv_path="${1:-}"
  [ -n "$venv_path" ] || return 1
  [ -f "$venv_path/bin/activate" ] || return 1
  # shellcheck disable=SC1090
  source "$venv_path/bin/activate"
  return 0
}

activate_uv() {
  # uv typically uses a standard venv; env is captured by sourcing activate.
  # Common convention: .venv created by `uv venv`.
  [ -d ".venv" ] && activate_venv ".venv" && return 0
  # Alternate common path (some setups): venv/
  [ -d "venv" ] && activate_venv "venv" && return 0
  return 1
}

activate_poetry() {
  has poetry || return 1
  [ -f "pyproject.toml" ] || return 1
  local venv_dir=""
  venv_dir="$(poetry env info -p 2>/dev/null || true)"
  [ -n "$venv_dir" ] || return 1
  activate_venv "$venv_dir"
}

activate_pdm() {
  has pdm || return 1
  [ -f "pyproject.toml" ] || return 1
  local venv_dir=""
  venv_dir="$(pdm venv --path 2>/dev/null || true)"
  [ -n "$venv_dir" ] || return 1
  activate_venv "$venv_dir"
}

activate_pipenv() {
  has pipenv || return 1
  [ -f "Pipfile" ] || return 1
  local venv_dir=""
  venv_dir="$(pipenv --venv 2>/dev/null || true)"
  [ -n "$venv_dir" ] || return 1
  activate_venv "$venv_dir"
}

activate_rye() {
  has rye || return 1
  # Rye can report the venv path; if it fails, fall back to .venv.
  local venv_dir=""
  venv_dir="$(rye show --venv 2>/dev/null || true)"
  if [ -n "$venv_dir" ]; then
    activate_venv "$venv_dir" && return 0
  fi
  [ -d ".venv" ] && activate_venv ".venv" && return 0
  return 1
}

activate_conda_like() {
  # Best-effort: activate a conda env by name from environment.yml/conda.yaml, if present.
  # This can be slower; kept after python-first managers.
  local yml=""
  if [ -f "environment.yml" ]; then yml="environment.yml"; fi
  if [ -z "$yml" ] && [ -f "conda.yaml" ]; then yml="conda.yaml"; fi
  [ -n "$yml" ] || return 1

  local conda_bin=""
  if has micromamba; then conda_bin="micromamba"; fi
  if [ -z "$conda_bin" ] && has mamba; then conda_bin="mamba"; fi
  if [ -z "$conda_bin" ] && has conda; then conda_bin="conda"; fi
  [ -n "$conda_bin" ] || return 1

  # Parse `name:` very conservatively.
  local env_name=""
  env_name="$(awk 'tolower($1)=="name:"{print $2; exit}' "$yml" 2>/dev/null || true)"
  [ -n "$env_name" ] || return 1

  if [ "$conda_bin" = "micromamba" ]; then
    # shellcheck disable=SC1090
    eval "$(micromamba shell hook -s bash)"
    micromamba activate "$env_name"
    return 0
  fi

  # conda/mamba: require the shell hook
  # shellcheck disable=SC1090
  eval "$("$conda_bin" shell.bash hook 2>/dev/null)"
  "$conda_bin" activate "$env_name"
  return 0
}

activated=0
if [ "$activated" -eq 0 ] && activate_pixi; then activated=1; fi
if [ "$activated" -eq 0 ] && activate_uv; then activated=1; fi
if [ "$activated" -eq 0 ] && activate_poetry; then activated=1; fi
if [ "$activated" -eq 0 ] && activate_pdm; then activated=1; fi
if [ "$activated" -eq 0 ] && activate_pipenv; then activated=1; fi
if [ "$activated" -eq 0 ] && activate_rye; then activated=1; fi
if [ "$activated" -eq 0 ] && activate_conda_like; then activated=1; fi

# Final fallback: if a local .venv exists, activate it (covers plain python venv too).
if [ "$activated" -eq 0 ] && [ -d ".venv" ]; then
  activate_venv ".venv" && activated=1 || true
fi

# Optional: load project-local dotenv if present (without error).
if has dotenv && [ -f ".env" ]; then
  dotenv -f .env >/dev/null 2>&1 || true
fi

unset -f has activate_pixi activate_venv activate_uv activate_poetry activate_pdm activate_pipenv activate_rye activate_conda_like
unset PROJECT_ROOT activated